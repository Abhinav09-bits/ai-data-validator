# ============================================================
# AI Data Validator — .gitignore
# ============================================================

# ── Node Dependencies ────────────────────────────────────────
node_modules/
.npm
.yarn

# ── Environment Variables (NEVER commit these) ───────────────
# Root level
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Backend .env files
backend/.env
backend/.env.local
backend/.env.development
backend/.env.production

# Frontend .env files
frontend/.env
frontend/.env.local
frontend/.env.development
frontend/.env.production

# Keep .env.example files (they have no real secrets)
!.env.example
!backend/.env.example
!frontend/.env.example

# ── Build Outputs ─────────────────────────────────────────────
dist/
build/
frontend/dist/
frontend/build/
backend/dist/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ── OS Files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Database ──────────────────────────────────────────────────
*.sql
*.dump
*.sqlite
*.db

# ── Secrets & Keys ────────────────────────────────────────────
*.pem
*.key
*.cert
secrets/

# ── WDK docs (downloaded locally) ─────────────────────────────
wdk-docs-index.txt
wdk-docs-full.txt

# ── Misc ──────────────────────────────────────────────────────
coverage/
.cache/
tmp/
temp/